{
  "mcpServers": {
    "quiverquant": {
      "command": ".venv-mcp/bin/python3",
      "args": ["-m", "src.mcp.quiverquant_server"],
      "env": {
        "QUIVER_QUANT_KEY": "${QUIVER_QUANT_KEY}"
      }
    },
    "worldmonitor-finance": {
      "command": ".venv-mcp/bin/python3",
      "args": ["-m", "src.mcp.worldmonitor_finance"]
    },
    "financial-datasets": {
      "type": "http",
      "url": "https://mcp.financialdatasets.ai/",
      "headers": {
        "X-API-KEY": "${FINANCIAL_DATASETS_API_KEY}"
      }
    },
    "claude-flow": {
      "command": "ruflo",
      "args": ["mcp", "start"],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid",
        "CLAUDE_FLOW_ENCRYPT_AT_REST": "${CLAUDE_FLOW_ENCRYPT_AT_REST}",
        "CLAUDE_FLOW_ENCRYPTION_KEY": "${CLAUDE_FLOW_ENCRYPTION_KEY}"
      },
      "autoStart": true
    }
  }
}
