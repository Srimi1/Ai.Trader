{
  "mcpServers": {
    "financial-datasets": {
      "command": "/Volumes/Srimi Drive 1/AI.Trader/.venv-mcp/bin/python3",
      "args": ["-m", "src.mcp.financial_datasets"],
      "cwd": "/Volumes/Srimi Drive 1/AI.Trader",
      "env": {
        "FINANCIAL_DATASETS_API_KEY": "${FINANCIAL_DATASETS_API_KEY}"
      }
    },
    "claude-flow": {
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    }
  }
}