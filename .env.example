# AI.Trader Environment Variables
# Copy to .env and fill in your values. NEVER commit .env.

# Anthropic API key for Claude-powered decision agent
ANTHROPIC_API_KEY=your_anthropic_key_here

# Alpha Vantage API key for news sentiment
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Quiver Quantitative API key (free tier works with 'demo')
QUIVER_QUANT_KEY=demo

# Alpaca — paper/live trading
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# Polygon.io (Massive data feed)
POLYGON_API_KEY=your_polygon_key_here

# Financial Datasets MCP
FINANCIAL_DATASETS_API_KEY=your_financial_datasets_key_here

# xAI Grok — real-time X/Twitter sentiment (Phase 6)
GROK_API_KEY=your_grok_key_here

# RuFlo encryption at rest (optional)
CLAUDE_FLOW_ENCRYPT_AT_REST=1
CLAUDE_FLOW_ENCRYPTION_KEY=generate_with_python_secrets_token_hex_32
